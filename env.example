# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MTN MoMo API — Collections (for receiving payments)
MOMO_COLLECTIONS_PRIMARY_KEY=your_collections_primary_key
MOMO_COLLECTIONS_USER_ID=your_collections_user_id
MOMO_COLLECTIONS_API_KEY=your_collections_api_key

# MTN MoMo API — Disbursements (for sending payments)
MOMO_DISBURSEMENTS_PRIMARY_KEY=your_disbursements_primary_key
MOMO_DISBURSEMENTS_USER_ID=your_disbursements_user_id
MOMO_DISBURSEMENTS_API_KEY=your_disbursements_api_key

# MTN MoMo environment: sandbox or production
MOMO_ENV=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_CURRENCY=EUR
MOMO_TARGET_ENVIRONMENT=sandbox

# App
PORT=3000
WEBHOOK_URL=https://your-app.railway.app
BOT_USERNAME=YourBotUsername

# Database (SQLite file path)
DB_PATH=./data/bot.db
